<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="8dp">

    <TextView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/dialog_icon_background"
        android:gravity="center"
        android:text="!"
        android:textColor="@color/calc_orange"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Enable Notification Access"
        android:textColor="#111827"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:lineSpacingExtra="3dp"
        android:text="Turn this on so Calculator Pro can read sender names and message text from supported app notifications."
        android:textColor="#4B5563"
        android:textSize="15sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:lineSpacingExtra="4dp"
        android:text="1. Tap Open settings.\n2. Select Calculator Pro.\n3. Allow notification access."
        android:textColor="#111827"
        android:textSize="15sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="#FFF7ED"
        android:lineSpacingExtra="3dp"
        android:padding="12dp"
        android:text="If Android says access is restricted, tap Fix restricted access first, open the three-dot menu on App info, choose Allow restricted settings, then return here."
        android:textColor="#9A3412"
        android:textSize="14sp" />
</LinearLayout>
